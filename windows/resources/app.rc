CAPTION "Client Filters"
FONT 9, "Segoe UI"
BEGIN
    LTEXT        "Show these kinds of posts in this timeline:", -1, 10, 8, 230, 9
    AUTOCHECKBOX "&Original posts (not replies or boosts)", IDC_CF_ORIGINAL, 10, 22, 230, 10
