#include <windows.h>
#include "resource.h"

// Embed the application manifest (ComCtl v6 + per-monitor DPI awareness).
// CREATEPROCESS_MANIFEST_RESOURCE_ID == 1, RT_MANIFEST == 24.
1 24 "app.manifest"

IDD_ADD_ACCOUNT DIALOGEX 0, 0, 260, 152
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Add Account"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "&Platform:", -1, 10, 12, 60, 10
    COMBOBOX        IDC_PLATFORM_COMBO, 80, 10, 168, 80, CBS_DROPDOWNLIST | WS_TABSTOP
    LTEXT           "&Instance:", IDC_SERVICE_LABEL, 10, 34, 66, 10
    EDITTEXT        IDC_SERVICE_EDIT, 80, 32, 168, 12, ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT           "&Handle:", IDC_HANDLE_LABEL, 10, 54, 66, 10
    EDITTEXT        IDC_HANDLE_EDIT, 80, 52, 168, 12, ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT           "App pass&word:", IDC_APPPASS_LABEL, 10, 74, 66, 10
    EDITTEXT        IDC_APPPASS_EDIT, 80, 72, 168, 12, ES_PASSWORD | ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT           "Mastodon opens your browser to authorize. Bluesky uses a handle and app password.",
                    -1, 10, 96, 240, 24
    DEFPUSHBUTTON   "OK", IDOK, 140, 130, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 196, 130, 50, 14
END

// All controls are present; the dialog hides the ones that don't apply and
// repositions the visible ones at runtime (see compose_dialog.cpp relayout).
IDD_COMPOSE DIALOGEX 0, 0, 320, 360
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Compose"
FONT 9, "Segoe UI"
BEGIN
    LTEXT      "", IDC_COMPOSE_CONTEXT, 8, 6, 304, 18
    LTEXT      "Content &warning:", IDC_COMPOSE_CW_LABEL, 8, 28, 100, 9
    EDITTEXT   IDC_COMPOSE_CW, 8, 38, 304, 12, ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT      "&Recipients:", IDC_COMPOSE_RCP_LABEL, 8, 54, 96, 9
    CONTROL    "", IDC_COMPOSE_RECIPIENTS, "SysListView32",
               LVS_LIST | LVS_SINGLESEL | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP,
               8, 64, 96, 88
    LTEXT      "&Post:", IDC_COMPOSE_POST_LABEL, 8, 54, 60, 9
    EDITTEXT   IDC_COMPOSE_EDIT, 8, 64, 304, 88,
               ES_MULTILINE | ES_WANTRETURN | ES_AUTOVSCROLL | WS_VSCROLL | WS_TABSTOP
    LTEXT      "&Visibility:", IDC_COMPOSE_VIS_LABEL, 8, 156, 50, 9
    COMBOBOX   IDC_COMPOSE_VISIBILITY, 8, 166, 120, 80, CBS_DROPDOWNLIST | WS_TABSTOP
    LTEXT      "&Language:", IDC_COMPOSE_LANG_LABEL, 8, 184, 50, 9
    COMBOBOX   IDC_COMPOSE_LANGUAGE, 8, 194, 120, 160, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX "Add p&oll", IDC_COMPOSE_POLL, 8, 212, 100, 10
    EDITTEXT   IDC_COMPOSE_POLL_OPT1, 8, 224, 240, 12, ES_AUTOHSCROLL | WS_TABSTOP
    EDITTEXT   IDC_COMPOSE_POLL_OPT2, 8, 238, 240, 12, ES_AUTOHSCROLL | WS_TABSTOP
    EDITTEXT   IDC_COMPOSE_POLL_OPT3, 8, 252, 240, 12, ES_AUTOHSCROLL | WS_TABSTOP
    EDITTEXT   IDC_COMPOSE_POLL_OPT4, 8, 266, 240, 12, ES_AUTOHSCROLL | WS_TABSTOP
    AUTOCHECKBOX "Allow &multiple choices", IDC_COMPOSE_POLL_MULTI, 8, 280, 160, 10
    LTEXT      "&Duration:", IDC_COMPOSE_DUR_LABEL, 8, 294, 50, 9
    COMBOBOX   IDC_COMPOSE_DURATION, 60, 292, 100, 120, CBS_DROPDOWNLIST | WS_TABSTOP
    AUTOCHECKBOX "&Schedule", IDC_COMPOSE_SCHEDULE, 8, 308, 80, 10
    CONTROL    "", IDC_COMPOSE_SCHED_TIME, "SysDateTimePick32",
               DTS_SHORTDATEFORMAT | WS_TABSTOP, 90, 306, 120, 14
    LTEXT      "", IDC_COMPOSE_COUNTER, 8, 326, 80, 10
    PUSHBUTTON "&Media...", IDC_COMPOSE_MEDIA, 8, 340, 54, 14
    LTEXT      "", IDC_COMPOSE_MEDIA_STATUS, 66, 342, 130, 10
    DEFPUSHBUTTON "&Post", IDOK, 200, 340, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 256, 340, 50, 14
END

IDD_ATTACHMENTS DIALOGEX 0, 0, 300, 200
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Attachments"
FONT 9, "Segoe UI"
BEGIN
    LTEXT      "&Attachments:", -1, 8, 8, 200, 9
    LISTBOX    IDC_ATT_LIST, 8, 20, 284, 80,
               LBS_NOTIFY | WS_BORDER | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON "A&dd...", IDC_ATT_ADD, 8, 104, 60, 14
    PUSHBUTTON "&Remove", IDC_ATT_REMOVE, 72, 104, 60, 14
    LTEXT      "Alt te&xt (image description):", IDC_ATT_ALT_LABEL, 8, 128, 200, 9
    EDITTEXT   IDC_ATT_ALT, 8, 140, 220, 14, ES_AUTOHSCROLL | WS_TABSTOP
    PUSHBUTTON "&Set", IDC_ATT_ALT_SET, 232, 140, 60, 14
    DEFPUSHBUTTON "&OK", IDOK, 186, 180, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 240, 180, 50, 14
END

// ---- Settings property-sheet pages ----
IDD_SET_GENERAL DIALOGEX 0, 0, 240, 160
STYLE DS_3DLOOK | DS_CONTROL | WS_CHILD | WS_CAPTION
CAPTION "General"
FONT 9, "Segoe UI"
BEGIN
    AUTOCHECKBOX "Use &Ctrl+Return to send posts (instead of Return)",
                 IDC_SET_CMDRETURN, 10, 12, 220, 12
END

IDD_SET_TIMELINES DIALOGEX 0, 0, 240, 176
STYLE DS_3DLOOK | DS_CONTROL | WS_CHILD | WS_CAPTION
CAPTION "Timelines"
FONT 9, "Segoe UI"
BEGIN
    LTEXT      "&Maximum posts to cache per timeline:", -1, 10, 13, 168, 9
    EDITTEXT   IDC_SET_CACHELIMIT, 180, 11, 42, 12, ES_NUMBER | ES_AUTOHSCROLL | WS_TABSTOP
    CONTROL    "", IDC_SET_CACHELIMIT_SPIN, "msctls_updown32",
               UDS_AUTOBUDDY | UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_ARROWKEYS | UDS_NOTHOUSANDS, 0, 0, 12, 12
    LTEXT      "How many posts to keep saved per timeline for instant startup (100-20000). This is storage, not how many load at once - see Advanced.",
               -1, 10, 30, 224, 26
    LTEXT      "&Auto-refresh:", -1, 10, 66, 56, 9
    COMBOBOX   IDC_SET_AUTOREFRESH, 68, 64, 114, 80, CBS_DROPDOWNLIST | WS_TABSTOP
    LTEXT      "Check timelines for new posts on this interval; new posts play that timeline's sound.",
               -1, 10, 82, 224, 18
    AUTOCHECKBOX "&Stream in real time (Mastodon)", IDC_SET_STREAMING, 10, 104, 224, 12
    LTEXT      "Receive new posts and notifications live over a streaming connection.",
               -1, 10, 118, 224, 16
    AUTOCHECKBOX "Show m&entions in the Notifications timeline", IDC_SET_SHOW_MENTIONS, 10, 138, 224, 12
    AUTOCHECKBOX "&Reverse timelines (newest at the bottom)", IDC_SET_REVERSE, 10, 154, 224, 12
END

IDD_SET_AUDIO DIALOGEX 0, 0, 240, 160
STYLE DS_3DLOOK | DS_CONTROL | WS_CHILD | WS_CAPTION
CAPTION "Audio"
FONT 9, "Segoe UI"
BEGIN
    AUTOCHECKBOX "&Play sounds", IDC_SET_SOUNDS, 10, 12, 120, 12
    LTEXT      "&Soundpack:", -1, 10, 32, 50, 9
    COMBOBOX   IDC_SET_SOUNDPACK, 62, 30, 152, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON "&Open Soundpacks Folder", IDC_SET_OPENPACKS, 10, 52, 130, 14
    LTEXT      "A Default pack is built in. Add your own pack to the soundpacks folder, then pick it here.",
               -1, 10, 72, 220, 18
END

IDD_SET_SPEECH DIALOGEX 0, 0, 240, 264
STYLE DS_3DLOOK | DS_CONTROL | WS_CHILD | WS_CAPTION
CAPTION "Speech"
FONT 9, "Segoe UI"
BEGIN
    LTEXT      "Choose which details the screen reader speaks, and their order, for each kind of row:",
               -1, 10, 10, 220, 18
    PUSHBUTTON "Configure &Posts...", IDC_SET_SPEECH_POSTS, 10, 36, 140, 16
    PUSHBUTTON "Configure &Users...", IDC_SET_SPEECH_USERS, 10, 58, 140, 16
    PUSHBUTTON "Configure &Notifications...", IDC_SET_SPEECH_NOTIFS, 10, 80, 140, 16
    LTEXT      "Content &warnings:", -1, 10, 106, 96, 9
    COMBOBOX   IDC_SET_CW_MODE, 110, 104, 120, 80, CBS_DROPDOWNLIST | WS_TABSTOP
    LTEXT      "Remove emoji from p&osts:", -1, 10, 126, 96, 9
    COMBOBOX   IDC_SET_POST_EMOJI, 110, 124, 120, 80, CBS_DROPDOWNLIST | WS_TABSTOP
    LTEXT      "Remove emoji from &names:", -1, 10, 146, 96, 9
    COMBOBOX   IDC_SET_NAME_EMOJI, 110, 144, 120, 80, CBS_DROPDOWNLIST | WS_TABSTOP
    LTEXT      "&Max usernames in a post (0 = all):", -1, 10, 166, 130, 9
    EDITTEXT   IDC_SET_MAX_MENTIONS, 144, 164, 40, 12, ES_NUMBER | ES_AUTOHSCROLL | WS_TABSTOP
    CONTROL    "", IDC_SET_MAX_MENTIONS_SPIN, "msctls_updown32",
               UDS_AUTOBUDDY | UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_ARROWKEYS | UDS_NOTHOUSANDS, 0, 0, 12, 12
    LTEXT      "Collapses a long leading @mention list (e.g. big reply chains). Custom = Mastodon :shortcode: emoji.",
               -1, 10, 184, 224, 18
    CONTROL    "&Repeat the item when you hit the top or bottom of a timeline (invisible interface / layer)",
               IDC_SET_REPEAT_EDGE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 10, 206, 224, 18
    CONTROL    "Use &absolute time (clock time), not relative (""5 minutes ago"")",
               IDC_SET_ABSOLUTE_TIME, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 10, 228, 224, 12
    LTEXT      "&Separator spoken between items:", -1, 10, 246, 130, 9
    EDITTEXT   IDC_SET_SEPARATOR, 144, 244, 86, 12, ES_AUTOHSCROLL | WS_TABSTOP
END

IDD_SPEECH_DETAIL DIALOGEX 0, 0, 264, 268
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Speech Details"
FONT 9, "Segoe UI"
BEGIN
    LTEXT      "Check which details are spoken, and order them:", -1, 8, 8, 248, 9
    CONTROL    "", IDC_SPEECH_DETAIL_LIST, "SysListView32",
               LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP,
               8, 22, 172, 150
    PUSHBUTTON "Move &Up\n(Ctrl+Up)", IDC_SPEECH_DETAIL_UP, 188, 22, 68, 20, BS_MULTILINE
    PUSHBUTTON "Move &Down\n(Ctrl+Down)", IDC_SPEECH_DETAIL_DOWN, 188, 46, 68, 20, BS_MULTILINE
    LTEXT      "Text &before the selected item:", -1, 8, 178, 248, 9
    EDITTEXT   IDC_SPEECH_DETAIL_BEFORE, 8, 188, 248, 12, ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT      "Text &after the selected item:", -1, 8, 204, 248, 9
    EDITTEXT   IDC_SPEECH_DETAIL_AFTER, 8, 214, 248, 12, ES_AUTOHSCROLL | WS_TABSTOP
    AUTOCHECKBOX "&No separator after the selected item", IDC_SPEECH_DETAIL_NOSEP, 8, 230, 248, 10
    DEFPUSHBUTTON "OK", IDOK, 150, 248, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 206, 248, 50, 14
END

IDD_SET_ADVANCED DIALOGEX 0, 0, 240, 160
STYLE DS_3DLOOK | DS_CONTROL | WS_CHILD | WS_CAPTION
CAPTION "Advanced"
FONT 9, "Segoe UI"
BEGIN
    LTEXT      "&API calls per timeline load (1-10):", -1, 10, 13, 150, 9
    EDITTEXT   IDC_SET_FETCHPAGES, 162, 11, 42, 12, ES_NUMBER | ES_AUTOHSCROLL | WS_TABSTOP
    CONTROL    "", IDC_SET_FETCHPAGES_SPIN, "msctls_updown32",
               UDS_AUTOBUDDY | UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_ARROWKEYS | UDS_NOTHOUSANDS, 0, 0, 12, 12
    LTEXT      "Posts loaded per refresh is about 40 x this number. Raise it to load more at once (slower). Applies to refresh and scrollback.",
               -1, 10, 30, 224, 26
END

